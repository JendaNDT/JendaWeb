{
  "redirects": [
    { "source": "/:path*", "has": [{ "type": "host", "value": "jenda-web.vercel.app" }], "destination": "https://jenda.cool/:path*", "permanent": true }
  ],
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" }
  ],
  "headers": [
    { "source": "/admin.html", "headers": [{ "key": "Cache-Control", "value": "no-store, max-age=0" }] },
    { "source": "/admin.jsx", "headers": [{ "key": "Cache-Control", "value": "no-store, max-age=0" }] },
    { "source": "/sw.js", "headers": [{ "key": "Cache-Control", "value": "no-store, max-age=0" }] }
  ]
}
